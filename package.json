{
  "name": "baton-cli",
  "version": "0.6.0",
  "description": "Git-backed session handoff for Claude Code",
  "type": "module",
  "bin": {
    "baton": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "claude-code",
    "session",
    "handoff",
    "sync"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quabug/baton.git"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
